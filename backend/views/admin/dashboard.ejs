<h2 class="mb-4">Dashboard</h2>

<div class="row g-4 mb-4">
  <div class="col-md-4 col-lg-2">
    <div class="card stat-card p-3 text-center">
      <div class="fs-2 fw-bold text-primary"><%= students %></div>
      <div class="text-muted small">Students</div>
    </div>
  </div>
  <div class="col-md-4 col-lg-2">
    <div class="card stat-card p-3 text-center">
      <div class="fs-2 fw-bold text-success"><%= staff %></div>
      <div class="text-muted small">Staff</div>
    </div>
  </div>
  <div class="col-md-4 col-lg-2">
    <div class="card stat-card p-3 text-center">
      <div class="fs-2 fw-bold text-info"><%= events %></div>
      <div class="text-muted small">Events</div>
    </div>
  </div>
  <div class="col-md-4 col-lg-2">
    <div class="card stat-card p-3 text-center">
      <div class="fs-2 fw-bold text-warning"><%= galleryCount %></div>
      <div class="text-muted small">Gallery</div>
    </div>
  </div>
  <div class="col-md-4 col-lg-2">
    <div class="card stat-card p-3 text-center">
      <div class="fs-2 fw-bold text-danger"><%= unreadContacts %></div>
      <div class="text-muted small">Unread Messages</div>
    </div>
  </div>
  <div class="col-md-4 col-lg-2">
    <div class="card stat-card p-3 text-center">
      <div class="fs-2 fw-bold text-secondary"><%= totalContacts %></div>
      <div class="text-muted small">Total Messages</div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card stat-card p-4">
      <h5>Quick Actions</h5>
      <div class="d-grid gap-2 mt-3">
        <a href="/admin/hero-sliders" class="btn btn-outline-primary">Manage Hero Sliders</a>
        <a href="/admin/gallery" class="btn btn-outline-primary">Manage Gallery</a>
        <a href="/admin/calendar-events" class="btn btn-outline-primary">Manage Events</a>
        <a href="/admin/contact-submissions" class="btn btn-outline-primary">View Messages</a>
        <a href="/admin/school-info" class="btn btn-outline-primary">Edit School Info</a>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card stat-card p-4">
      <h5>Content Management</h5>
      <div class="d-grid gap-2 mt-3">
        <a href="/admin/students" class="btn btn-outline-success">Manage Students</a>
        <a href="/admin/staff" class="btn btn-outline-success">Manage Staff</a>
        <a href="/admin/testimonials" class="btn btn-outline-success">Manage Testimonials</a>
        <a href="/admin/programs" class="btn btn-outline-success">Manage Programs</a>
        <a href="/admin/departments" class="btn btn-outline-success">Manage Departments</a>
      </div>
    </div>
  </div>
</div>
